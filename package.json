{
  "name": "guardian-discord-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Configurable Discord server moderator and manager bot.",
  "type": "module",
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "deploy:commands": "npm run build && node dist/deployCommands.js"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  }
}
