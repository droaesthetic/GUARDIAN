DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id

# Optional: restrict command deploys to one guild while developing.
DISCORD_GUILD_ID=

# Optional: custom classifier that returns {"unsafe":true,"reason":"..."}.
NUDITY_PROVIDER_URL=

# Optional: Sightengine nudity detection. Leave blank unless you have Sightengine API keys.
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
SIGHTENGINE_NUDITY_THRESHOLD=0.65

# Optional: where Guardian stores runtime config and warnings.
GUARDIAN_DATA_DIR=data
